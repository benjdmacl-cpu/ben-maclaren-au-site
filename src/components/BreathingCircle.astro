---
// Live CSS-only animation for the one featured/interactive resource card
// (see Resources §5.1). No JS — a 12s keyframe cycle approximates
// "in for 4, hold for 2, out for 6", matching the paced-breathing copy.
---

<div class="breathing-circle" aria-hidden="true">
	<span class="ring"></span>
	<span class="dot"></span>
</div>

<style>
	.breathing-circle {
		position: relative;
		width: 44px;
		height: 44px;
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.ring {
		position: absolute;
		inset: 0;
		border: var(--border-hairline) solid var(--color-accent);
		border-radius: 50%;
		opacity: 0.35;
	}

	.dot {
		display: block;
		width: 60%;
		height: 60%;
		border-radius: 50%;
		background: var(--color-accent);
		animation: breathe 12s ease-in-out infinite;
	}

	@keyframes breathe {
		0% {
			transform: scale(0.55);
			opacity: 0.7;
		}
		33% {
			transform: scale(1);
			opacity: 1;
		}
		50% {
			transform: scale(1);
			opacity: 1;
		}
		100% {
			transform: scale(0.55);
			opacity: 0.7;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.dot {
			animation: none;
			transform: scale(0.85);
		}
	}
</style>
