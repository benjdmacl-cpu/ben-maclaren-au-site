<section class="contact" id="contact">
	<svg class="contact-motif" viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
		<circle cx="100" cy="100" r="10" fill="none" stroke-width="1.4"></circle>
		<circle cx="100" cy="100" r="34" fill="none" stroke-width="1.2"></circle>
		<circle cx="100" cy="100" r="62" fill="none" stroke-width="1"></circle>
		<circle cx="100" cy="100" r="94" fill="none" stroke-width="0.8"></circle>
	</svg>
	<div class="wrap">
		<span class="eyebrow">Get in touch</span>
		<h2>Book a conversation, no pressure to commit further.</h2>
		<div class="contact-grid">
			<div class="contact-item">
				<span class="label">Email</span>
				<a class="value" id="email-link" href="#contact">Email</a>
			</div>
		</div>
	</div>
</section>

<style>
	.contact {
		background: var(--color-bg-dark);
		color: var(--color-text-on-dark);
		padding: var(--space-25) 0 var(--space-20);
		position: relative;
		overflow: hidden;
	}

	.contact-motif {
		position: absolute;
		bottom: -80px;
		left: -80px;
		width: 360px;
		height: 360px;
		opacity: 0.14;
		color: var(--cream);
	}

	.contact-motif circle {
		stroke: currentColor;
	}

	.contact .wrap {
		position: relative;
		z-index: 2;
	}

	.contact .eyebrow {
		color: var(--color-accent-on-dark);
		margin-bottom: var(--space-4);
		display: block;
	}

	.contact h2 {
		color: var(--color-text-on-dark);
		font-size: var(--fs-contact-heading);
		max-width: 520px;
		margin-bottom: var(--space-14);
	}

	.contact-grid {
		max-width: 320px;
	}

	.contact-item .label {
		font-family: var(--font-mono);
		font-size: var(--fs-meta-label);
		letter-spacing: var(--ls-meta-label);
		text-transform: uppercase;
		color: var(--color-accent-on-dark-muted);
		margin-bottom: var(--space-2-5);
		display: block;
	}

	.contact-item .value {
		font-family: var(--font-display);
		font-size: var(--fs-tagline);
		color: var(--color-text-on-dark);
		text-decoration: none;
	}

	.contact-item .value:hover {
		color: var(--color-accent-on-dark-hover);
	}
</style>

<script>
	// Base64-encoded rather than a plain string: the build minifier constant-folds
	// simple string concatenation back into the literal address at build time, which
	// would defeat the point. atob() is a runtime-only call, so the decoded address
	// never appears as text anywhere in the built output for scrapers to find.
	const link = document.getElementById('email-link');
	if (link instanceof HTMLAnchorElement) {
		const address = atob('aGVsbG9AYmVubWFjbGFyZW4uY29tLmF1');
		link.href = `mailto:${address}`;
		link.textContent = address;

		link.addEventListener('click', (e) => {
			e.preventDefault();
			navigator.clipboard?.writeText(address);
			const original = link.textContent;
			link.textContent = 'Copied!';
			setTimeout(() => {
				link.textContent = original;
			}, 1500);
		});
	}
</script>
