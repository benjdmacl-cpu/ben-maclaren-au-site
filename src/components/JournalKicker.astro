---
import FormattedDate from './FormattedDate.astro';
import { CATEGORY_LABELS, TYPE_LABELS } from '../lib/journal-labels';

interface Props {
	articleType: 'response' | 'research';
	category: string;
	date: Date;
}

const { articleType, category, date } = Astro.props;
---

<span class:list={['kicker', articleType === 'research' && 'kicker-research']}>
	{TYPE_LABELS[articleType]} · {CATEGORY_LABELS[category]} · <FormattedDate date={date} />
</span>

<style>
	.kicker {
		font-family: var(--font-mono);
		font-size: var(--fs-eyebrow);
		letter-spacing: var(--ls-caps);
		text-transform: uppercase;
		color: var(--color-accent);
		display: block;
	}

	/* Research pieces read in a quieter register than response pieces. */
	.kicker-research {
		color: var(--color-text-muted);
	}
</style>
