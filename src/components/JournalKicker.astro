---
import FormattedDate from './FormattedDate.astro';
import { CATEGORY_LABELS, TYPE_LABELS } from '../lib/journal-labels';

interface Props {
	articleType: 'response' | 'research' | 'guide';
	category: string;
	date: Date;
}

const { articleType, category, date } = Astro.props;
---

<span class:list={['kicker', articleType !== 'response' && 'kicker-muted']}>
	{TYPE_LABELS[articleType]} · {CATEGORY_LABELS[category]} · <FormattedDate date={date} />
</span>

<style>
	.kicker {
		font-family: var(--font-mono);
		font-size: var(--fs-eyebrow);
		letter-spacing: var(--ls-caps);
		text-transform: uppercase;
		color: var(--color-accent);
		display: block;
	}

	/* Only response pieces get the accent — research and (in principle)
	   guide read in a quieter register. In practice this component is
	   never invoked for guides, since guide entries leave category unset
	   and JournalPost falls back to a plain date-only meta line instead. */
	.kicker-muted {
		color: var(--color-text-muted);
	}
</style>
