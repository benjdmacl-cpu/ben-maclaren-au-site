---
import { Image } from 'astro:assets';
import portrait from '../assets/portrait/ben-maclaren.png';
---

<section class="meet" id="meet">
	<div class="wrap">
		<div class="meet-portrait">
			<svg class="meet-motif" viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
				<circle cx="100" cy="100" r="70" fill="none" stroke-width="1" opacity="0.4"></circle>
				<circle cx="100" cy="100" r="84" fill="none" stroke-width="0.9" opacity="0.28"></circle>
				<circle cx="100" cy="100" r="98" fill="none" stroke-width="0.8" opacity="0.18"></circle>
			</svg>
			<div class="frame">
				<Image src={portrait} alt="Ben Maclaren" width={420} height={420} />
			</div>
			<p class="meet-caption">Ben Maclaren · Canberra, ACT</p>
		</div>
		<div class="meet-text">
			<span class="eyebrow">Meet Ben</span>
			<h2>Hi — good to meet you.</h2>
			<p class="meet-body">
				If you've made it this far, you've likely already done the hardest part — deciding to look for
				someone. I try to make everything after that feel unremarkable: an honest conversation, at your
				pace, with someone glad you're here.
			</p>
			<p class="meet-signoff">No pressure, no scripts — just a place to start.</p>
		</div>
	</div>
</section>

<style>
	.meet {
		padding: 110px 0;
		border-bottom: 1px solid var(--line);
		background: var(--cream-deep);
	}

	.meet .wrap {
		display: grid;
		grid-template-columns: 210px 1fr;
		gap: 56px;
		align-items: center;
	}

	.meet-portrait {
		max-width: 210px;
		position: relative;
	}

	.meet-motif {
		position: absolute;
		top: 50%;
		left: 50%;
		width: 150%;
		height: 150%;
		transform: translate(-50%, -50%);
		z-index: 0;
		pointer-events: none;
		color: var(--terracotta);
	}

	.meet-motif circle {
		stroke: currentColor;
	}

	.frame {
		position: relative;
		z-index: 1;
		aspect-ratio: 1 / 1;
		border-radius: 50%;
		overflow: hidden;
		border: 1px solid var(--line);
		box-shadow: 0 1px 2px rgba(56, 44, 36, 0.06);
	}

	.frame :global(img) {
		width: 100%;
		height: 100%;
		object-fit: cover;
		filter: sepia(8%) saturate(92%);
		display: block;
	}

	.meet-caption {
		font-family: 'IBM Plex Mono', monospace;
		font-size: 12px;
		letter-spacing: 0.06em;
		color: var(--sage);
		text-align: left;
		margin: 16px 0 0;
	}

	.meet-text .eyebrow {
		margin-bottom: 18px;
		display: block;
	}

	.meet-text h2 {
		font-size: 34px;
		line-height: 1.15;
		max-width: 480px;
		margin-bottom: 20px;
	}

	.meet-body {
		font-size: 16.5px;
		color: var(--ink-soft);
		max-width: 520px;
		margin: 0;
	}

	.meet-signoff {
		font-family: 'Fraunces', serif;
		font-style: italic;
		font-size: 19px;
		color: var(--ink);
		margin: 28px 0 0;
	}

	@media (max-width: 820px) {
		.meet .wrap {
			grid-template-columns: 1fr;
			gap: 32px;
		}

		.meet-portrait {
			max-width: 150px;
		}

		.meet-text h2 {
			max-width: none;
		}
	}
</style>
