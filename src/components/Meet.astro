---
import { Image } from 'astro:assets';
import portrait from '../assets/portrait/ben-maclaren.png';
---

<section class="meet" id="meet">
	<div class="wrap">
		<div class="meet-portrait">
			<svg class="meet-motif" viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
				<circle cx="100" cy="100" r="70" fill="none" stroke-width="1" opacity="0.4"></circle>
				<circle cx="100" cy="100" r="84" fill="none" stroke-width="0.9" opacity="0.28"></circle>
				<circle cx="100" cy="100" r="98" fill="none" stroke-width="0.8" opacity="0.18"></circle>
			</svg>
			<div class="frame">
				<Image src={portrait} alt="Ben Maclaren" width={420} height={420} />
			</div>
			<p class="meet-caption">Ben Maclaren · Canberra, ACT</p>
		</div>
		<div class="meet-text">
			<span class="eyebrow">Meet Ben</span>
			<h2>Hi — good to meet you.</h2>
			<p class="meet-body">
				If you've made it this far, you've likely already done the hardest part — deciding to look for
				someone. I try to make everything after that feel unremarkable: an honest conversation, at your
				pace, with someone glad you're here.
			</p>
			<p class="meet-signoff">No pressure, no scripts — just a place to start.</p>
		</div>
	</div>
</section>

<style>
	.meet {
		padding: var(--space-27-5) 0;
		border-bottom: var(--border-hairline) solid var(--color-border);
		background: var(--color-bg-card);
	}

	.meet .wrap {
		display: grid;
		grid-template-columns: 210px 1fr;
		gap: var(--space-14);
		align-items: center;
	}

	.meet-portrait {
		max-width: 210px;
		position: relative;
	}

	.meet-motif {
		position: absolute;
		top: 50%;
		left: 50%;
		width: 150%;
		height: 150%;
		transform: translate(-50%, -50%);
		z-index: 0;
		pointer-events: none;
		color: var(--terracotta);
	}

	.meet-motif circle {
		stroke: currentColor;
	}

	.frame {
		position: relative;
		z-index: 1;
		aspect-ratio: 1 / 1;
		border-radius: 50%;
		overflow: hidden;
		border: var(--border-hairline) solid var(--color-border);
		box-shadow: 0 1px 2px rgba(56, 44, 36, 0.06);
	}

	.frame :global(img) {
		width: 100%;
		height: 100%;
		object-fit: cover;
		filter: sepia(8%) saturate(92%);
		display: block;
	}

	.meet-caption {
		font-family: var(--font-mono);
		font-size: var(--fs-caption);
		letter-spacing: var(--ls-tight-label);
		color: var(--color-text-muted);
		text-align: left;
		margin: var(--space-4) 0 0;
	}

	.meet-text .eyebrow {
		margin-bottom: var(--space-5-5);
		display: block;
	}

	.meet-text h2 {
		font-size: var(--fs-display);
		line-height: var(--lh-article-title);
		max-width: 480px;
		margin-bottom: var(--space-5);
	}

	.meet-body {
		font-size: var(--fs-prose-body);
		color: var(--color-text-secondary);
		max-width: 520px;
		margin: 0;
	}

	.meet-signoff {
		font-family: var(--font-display);
		font-style: italic;
		font-size: var(--fs-brand);
		color: var(--color-text-primary);
		margin: var(--space-7) 0 0;
	}

	@media (max-width: 820px) {
		.meet .wrap {
			grid-template-columns: 1fr;
			gap: var(--space-8);
		}

		.meet-portrait {
			max-width: 150px;
		}

		.meet-text h2 {
			max-width: none;
		}
	}
</style>
