---
import FormattedDate from '../components/FormattedDate.astro';
import JournalKicker from '../components/JournalKicker.astro';
import SourcesBlock from '../components/SourcesBlock.astro';
import Layout from './Layout.astro';

type Reference = { label: string; url?: string };

type Props = {
	title: string;
	description: string;
	date: Date;
	category?: string;
	articleType?: 'response' | 'research' | 'guide';
	references?: Reference[];
	substackUrl?: string;
	pageTitle?: string;
	eyebrow?: string;
	backHref?: string;
	backLabel?: string;
	noindex?: boolean;
};

const {
	title,
	description,
	date,
	category,
	articleType,
	references,
	substackUrl,
	pageTitle = title,
	eyebrow = 'Journal',
	backHref = '/journal',
	backLabel = '← Journal',
	noindex,
} = Astro.props;

const hasReferences = Boolean(references && references.length > 0);
---

<Layout title={pageTitle} description={description} noindex={noindex}>
	<article class="journal-article">
		<div class="wrap">
			<a class="back-link" href={backHref}>{backLabel}</a>
			<div class="article-head">
				<span class="eyebrow">{eyebrow}</span>
				<h1>{title}</h1>
				<div class="meta-row">
					{
						category && articleType ? (
							<JournalKicker articleType={articleType} category={category} date={date} />
						) : (
							<div class="meta">
								<FormattedDate date={date} />
							</div>
						)
					}
					{(hasReferences || substackUrl) && (
						<div class="quick-links">
							{hasReferences && (
								<a class="quick-link" href="#references">
									↓ Sources
								</a>
							)}
							{substackUrl && (
								<a class="quick-link" href={substackUrl} target="_blank" rel="noopener noreferrer">
									↗ Read on Substack
								</a>
							)}
						</div>
					)}
				</div>
			</div>
			<div class="prose">
				<slot />
			</div>
			<SourcesBlock references={references} />
		</div>
	</article>
</Layout>

<style>
	.journal-article {
		padding: var(--space-22-5) 0 var(--space-27-5);
	}

	.back-link {
		font-family: var(--font-mono);
		font-size: var(--fs-caption);
		letter-spacing: var(--ls-label);
		text-transform: uppercase;
		text-decoration: none;
		color: var(--color-text-secondary);
		display: inline-block;
		margin-bottom: var(--space-12);
	}

	.back-link:hover {
		color: var(--color-accent);
	}

	.article-head {
		max-width: 720px;
		margin: 0 auto var(--space-12);
	}

	.article-head .eyebrow {
		margin-bottom: var(--space-4-5);
		display: block;
	}

	.article-head h1 {
		font-size: var(--fs-article-title);
		line-height: var(--lh-article-title);
		margin-bottom: var(--space-5-5);
	}

	.meta-row {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		flex-wrap: wrap;
		gap: var(--space-2) var(--space-5);
	}

	.meta {
		font-family: var(--font-mono);
		font-size: var(--fs-caption);
		letter-spacing: var(--ls-wide-label);
		text-transform: uppercase;
		color: var(--color-text-muted);
	}

	.quick-links {
		display: flex;
		align-items: center;
		flex-wrap: wrap;
		gap: var(--space-4);
	}

	.quick-link {
		font-family: var(--font-mono);
		font-size: var(--fs-micro);
		letter-spacing: var(--ls-label);
		text-transform: uppercase;
		color: var(--color-text-muted);
		text-decoration: none;
		white-space: nowrap;
	}

	.quick-link:hover {
		color: var(--color-accent);
	}

	.prose {
		max-width: 720px;
		margin: 0 auto;
		font-size: var(--fs-prose-body);
		color: var(--color-text-secondary);
	}

	.prose :global(p) {
		margin: 0 0 var(--space-5-5);
	}

	.prose :global(h2) {
		font-family: var(--font-display);
		font-size: var(--fs-h1);
		color: var(--color-text-primary);
		margin: var(--space-11) 0 var(--space-5);
	}

	.prose :global(h3) {
		font-family: var(--font-display);
		font-size: var(--fs-prose-h3);
		color: var(--color-text-primary);
		margin: var(--space-9) 0 var(--space-4);
	}

	.prose :global(a) {
		color: var(--color-accent-link);
		text-decoration: underline;
	}

	.prose :global(a:hover) {
		color: var(--color-accent);
	}

	.prose :global(strong) {
		color: var(--color-text-primary);
	}

	.prose :global(blockquote) {
		font-family: var(--font-display);
		font-style: italic;
		font-size: var(--fs-prose-quote);
		color: var(--color-text-primary);
		border-left: var(--border-strong) solid var(--color-accent-link);
		padding-left: var(--space-5-5);
		margin: var(--space-9) 0;
	}

	.prose :global(blockquote p) {
		margin: 0;
	}

	.prose :global(ul),
	.prose :global(ol) {
		margin: 0 0 var(--space-5-5);
		padding-left: var(--space-5-5);
	}

	.prose :global(li) {
		margin-bottom: var(--space-2);
	}

	.prose :global(hr) {
		border: none;
		border-top: var(--border-hairline) solid var(--color-border);
		margin: var(--space-11) 0;
	}

	.prose :global(code) {
		font-family: var(--font-mono);
		font-size: 0.9em;
		background: var(--color-bg-card);
		padding: var(--space-0-5) var(--space-1-5);
		border-radius: var(--radius-sm);
	}

	@media (max-width: 720px) {
		.journal-article {
			padding: var(--space-15) 0 var(--space-20);
		}
	}

	@media (max-width: 480px) {
		.meta-row {
			flex-direction: column;
			align-items: flex-start;
			gap: var(--space-2-5);
		}
	}
</style>
