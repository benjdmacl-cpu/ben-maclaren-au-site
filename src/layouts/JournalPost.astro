---
import FormattedDate from '../components/FormattedDate.astro';
import Layout from './Layout.astro';

type Props = {
	title: string;
	description: string;
	date: Date;
	pageTitle?: string;
	eyebrow?: string;
	backHref?: string;
	backLabel?: string;
};

const {
	title,
	description,
	date,
	pageTitle = title,
	eyebrow = 'Journal',
	backHref = '/journal',
	backLabel = '← Journal',
} = Astro.props;
---

<Layout title={pageTitle} description={description}>
	<article class="journal-article">
		<div class="wrap">
			<a class="back-link" href={backHref}>{backLabel}</a>
			<div class="article-head">
				<span class="eyebrow">{eyebrow}</span>
				<h1>{title}</h1>
				<div class="meta">
					<FormattedDate date={date} />
				</div>
			</div>
			<div class="prose">
				<slot />
			</div>
		</div>
	</article>
</Layout>

<style>
	.journal-article {
		padding: 90px 0 110px;
	}

	.back-link {
		font-family: 'IBM Plex Mono', monospace;
		font-size: 12.5px;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		text-decoration: none;
		color: var(--ink-soft);
		display: inline-block;
		margin-bottom: 48px;
	}

	.back-link:hover {
		color: var(--terracotta-deep);
	}

	.article-head {
		max-width: 720px;
		margin: 0 auto 48px;
	}

	.article-head .eyebrow {
		margin-bottom: 18px;
		display: block;
	}

	.article-head h1 {
		font-size: clamp(32px, 4vw, 44px);
		line-height: 1.15;
		margin-bottom: 22px;
	}

	.meta {
		font-family: 'IBM Plex Mono', monospace;
		font-size: 12.5px;
		letter-spacing: 0.16em;
		text-transform: uppercase;
		color: var(--ink-soft);
	}

	.prose {
		max-width: 720px;
		margin: 0 auto;
		font-size: 16.5px;
		color: var(--ink-soft);
	}

	.prose :global(p) {
		margin: 0 0 22px;
	}

	.prose :global(h2) {
		font-family: 'Fraunces', serif;
		font-size: 26px;
		color: var(--ink);
		margin: 44px 0 20px;
	}

	.prose :global(h3) {
		font-family: 'Fraunces', serif;
		font-size: 21px;
		color: var(--ink);
		margin: 36px 0 16px;
	}

	.prose :global(a) {
		color: var(--terracotta);
		text-decoration: underline;
	}

	.prose :global(a:hover) {
		color: var(--terracotta-deep);
	}

	.prose :global(strong) {
		color: var(--ink);
	}

	.prose :global(blockquote) {
		font-family: 'Fraunces', serif;
		font-style: italic;
		font-size: 22px;
		color: var(--ink);
		border-left: 2px solid var(--terracotta);
		padding-left: 22px;
		margin: 36px 0;
	}

	.prose :global(blockquote p) {
		margin: 0;
	}

	.prose :global(ul),
	.prose :global(ol) {
		margin: 0 0 22px;
		padding-left: 22px;
	}

	.prose :global(li) {
		margin-bottom: 8px;
	}

	.prose :global(hr) {
		border: none;
		border-top: 1px solid var(--line);
		margin: 44px 0;
	}

	.prose :global(code) {
		font-family: 'IBM Plex Mono', monospace;
		font-size: 0.9em;
		background: var(--cream-deep);
		padding: 2px 6px;
		border-radius: 2px;
	}

	@media (max-width: 720px) {
		.journal-article {
			padding: 60px 0 80px;
		}
	}
</style>
