---
import { getCollection } from 'astro:content';
import JournalKicker from '../../components/JournalKicker.astro';
import Layout from '../../layouts/Layout.astro';
import { CATEGORY_LABELS, CATEGORY_ORDER } from '../../lib/journal-labels';

// TODO: placeholder — swap for the real Substack publication URL when available.
const SUBSTACK_URL = 'https://thejournal.substack.com';

const posts = (await getCollection('journal', ({ data }) => !data.draft)).sort(
	(a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);

// Lead and secondary are reserved for response-type posts — a research piece
// is never promoted above a response piece, even if it's more recent.
const responsePosts = posts.filter((post) => post.data.articleType === 'response');
const lead = responsePosts[0];
const secondary = responsePosts[1];

// Tertiary (and "older") draw from everything else, both types, by recency —
// this is where research pieces become eligible.
const usedIds = new Set([lead?.id, secondary?.id].filter(Boolean));
const remaining = posts.filter((post) => !usedIds.has(post.id));
const tertiary = remaining.slice(0, 3);
const older = remaining.slice(3);

const categoriesInUse = CATEGORY_ORDER.filter((cat) => posts.some((post) => post.data.category === cat));

const issueLabel = lead
	? `Issue — ${lead.data.date.toLocaleDateString('en-us', { month: 'long', year: 'numeric' })}`
	: null;
---

<Layout
	title="Journal — Ben Maclaren"
	description="Field notes on counselling, presence, and change from Ben Maclaren, counsellor in Canberra, ACT."
>
	<div class="wrap top-nav">
		<a class="back-link" href="/">← Home</a>
	</div>

	<section class="masthead">
		<svg class="masthead-motif" viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
			<circle cx="100" cy="100" r="6" fill="none" stroke-width="1.4"></circle>
			<circle cx="100" cy="100" r="20" fill="none" stroke-width="1.4"></circle>
			<circle cx="100" cy="100" r="38" fill="none" stroke-width="1.2" opacity="0.75"></circle>
			<circle cx="100" cy="100" r="60" fill="none" stroke-width="1" opacity="0.5"></circle>
			<circle cx="100" cy="100" r="86" fill="none" stroke-width="0.8" opacity="0.3"></circle>
		</svg>
		<div class="wrap">
			<span class="kicker">Field notes on the work</span>
			<h1>The Journal</h1>
		</div>
	</section>

	{
		!lead ? (
			<section class="journal-empty">
				<div class="wrap">
					<p class="empty">No articles published yet — check back soon.</p>
				</div>
			</section>
		) : (
			<>
				<section class="issue-bar">
					<div class="wrap issue-bar-inner">
						<span class="issue-label">{issueLabel}</span>
						<div class="tag-list">
							{categoriesInUse.map((cat, i) => (
								<>
									{i > 0 && <span class="tag-sep">·</span>}
									<a class="tag" href={`/journal?category=${cat}`}>
										{CATEGORY_LABELS[cat]}
									</a>
								</>
							))}
						</div>
					</div>
				</section>

				<section class="rank-primary">
					<div class="wrap rank-primary-inner">
						<article class="lead-story">
							<JournalKicker
								articleType={lead.data.articleType}
								category={lead.data.category}
								date={lead.data.date}
							/>
							<h2>
								<a href={`/journal/${lead.id}/`}>{lead.data.title}</a>
							</h2>
							<p class="excerpt-columns">{lead.data.description}</p>
						</article>
						{secondary && (
							<article class="secondary-story">
								<JournalKicker
									articleType={secondary.data.articleType}
									category={secondary.data.category}
									date={secondary.data.date}
								/>
								<h3>
									<a href={`/journal/${secondary.id}/`}>{secondary.data.title}</a>
								</h3>
								<p class="excerpt">{secondary.data.description}</p>
							</article>
						)}
					</div>
				</section>

				{tertiary.length > 0 && (
					<section class="rank-tertiary">
						<div class="wrap tertiary-grid" style={`--tertiary-count: ${tertiary.length}`}>
							{tertiary.map((post) => (
								<article class="tertiary-item">
									<JournalKicker
										articleType={post.data.articleType}
										category={post.data.category}
										date={post.data.date}
									/>
									<h3>
										<a href={`/journal/${post.id}/`}>{post.data.title}</a>
									</h3>
								</article>
							))}
						</div>
					</section>
				)}

				{older.length > 0 && (
					<div class="older-entries">
						<a class="older-link" href="/journal/archive">
							Older entries →
						</a>
					</div>
				)}

				<div class="substack-cta">
					<div class="wrap">
						<span class="substack-label">Also published on Substack</span>
						<a class="substack-link" href={SUBSTACK_URL} target="_blank" rel="noopener noreferrer">
							Read these on Substack →
						</a>
					</div>
				</div>
			</>
		)
	}
</Layout>

<style>
	.top-nav {
		padding-top: var(--space-10);
	}

	.back-link {
		font-family: var(--font-mono);
		font-size: var(--fs-caption);
		letter-spacing: var(--ls-label);
		text-transform: uppercase;
		text-decoration: none;
		color: var(--color-text-secondary);
		display: inline-block;
	}

	.back-link:hover {
		color: var(--color-accent);
	}

	.kicker {
		font-family: var(--font-mono);
		font-size: var(--fs-eyebrow);
		letter-spacing: var(--ls-caps);
		text-transform: uppercase;
		color: var(--color-accent);
		display: block;
	}

	/* ---------- Masthead ---------- */
	.masthead {
		position: relative;
		overflow: hidden;
		text-align: center;
		padding: var(--space-12) 0 var(--space-10);
		border-bottom: var(--border-strong) solid var(--color-border-strong);
	}

	.masthead-motif {
		position: absolute;
		top: -30px;
		right: -30px;
		width: 220px;
		height: 220px;
		opacity: 0.18;
		z-index: 0;
		color: var(--terracotta);
		pointer-events: none;
	}

	.masthead-motif circle {
		stroke: currentColor;
	}

	.masthead .wrap {
		position: relative;
		z-index: 1;
	}

	.masthead .kicker {
		margin: 0 0 var(--space-3-5);
	}

	.masthead h1 {
		font-size: var(--fs-display);
		margin: 0;
	}

	/* ---------- Issue meta bar ---------- */
	.issue-bar {
		border-bottom: var(--border-hairline) solid var(--color-border);
		padding: var(--space-4-5) 0;
	}

	.issue-bar-inner {
		display: flex;
		align-items: center;
		justify-content: space-between;
		flex-wrap: wrap;
		gap: var(--space-3);
	}

	.issue-label {
		font-family: var(--font-mono);
		font-size: var(--fs-eyebrow);
		letter-spacing: var(--ls-caps);
		text-transform: uppercase;
		color: var(--color-text-muted);
	}

	.tag-list {
		display: flex;
		align-items: center;
		flex-wrap: wrap;
		gap: var(--space-2-5);
	}

	.tag {
		font-family: var(--font-mono);
		font-size: var(--fs-eyebrow);
		letter-spacing: var(--ls-caps);
		text-transform: uppercase;
		color: var(--color-accent);
		text-decoration: none;
	}

	.tag:hover {
		color: var(--color-text-primary);
	}

	.tag-sep {
		color: var(--color-text-muted);
		font-size: var(--fs-eyebrow);
	}

	/* ---------- Lead + secondary ---------- */
	.rank-primary {
		padding: var(--space-12) 0;
	}

	.rank-primary-inner {
		display: grid;
		grid-template-columns: 58% 42%;
		gap: 0;
		align-items: start;
	}

	.rank-primary-inner:not(:has(.secondary-story)) .lead-story {
		border-right: none;
		padding-right: 0;
	}

	.lead-story {
		border-right: var(--border-hairline) solid var(--color-border);
		padding-right: var(--space-12);
	}

	.lead-story h2 {
		font-family: var(--font-display);
		font-size: var(--fs-h1);
		line-height: var(--lh-tight);
		margin: var(--space-2-5) 0 0;
	}

	.lead-story h2 a {
		color: var(--color-text-primary);
		text-decoration: none;
	}

	.lead-story h2 a:hover {
		color: var(--color-accent);
	}

	.lead-story .excerpt-columns {
		column-count: 2;
		column-gap: var(--space-5);
		column-fill: balance;
		font-size: var(--fs-caption);
		line-height: var(--lh-body);
		color: var(--color-text-secondary);
		margin: var(--space-4) 0 0;
	}

	.secondary-story {
		padding-left: var(--space-12);
	}

	.secondary-story h3 {
		font-family: var(--font-display);
		font-size: var(--fs-h2);
		line-height: var(--lh-snug);
		margin: var(--space-2) 0 0;
	}

	.secondary-story h3 a {
		color: var(--color-text-primary);
		text-decoration: none;
	}

	.secondary-story h3 a:hover {
		color: var(--color-accent);
	}

	.secondary-story .excerpt {
		font-size: var(--fs-caption);
		line-height: var(--lh-body);
		color: var(--color-text-secondary);
		margin: var(--space-3) 0 0;
	}

	/* ---------- Tertiary rank grid ---------- */
	.rank-tertiary {
		border-top: var(--border-hairline) solid var(--color-border-strong);
		padding: var(--space-12) 0;
	}

	.tertiary-grid {
		display: grid;
		grid-template-columns: repeat(var(--tertiary-count, 3), 1fr);
	}

	.tertiary-item {
		padding: 0 var(--space-8);
	}

	.tertiary-item:first-child {
		padding-left: 0;
	}

	.tertiary-item:last-child {
		padding-right: 0;
	}

	.tertiary-item:not(:last-child) {
		border-right: var(--border-hairline) solid var(--color-border);
	}

	.tertiary-item h3 {
		font-family: var(--font-display);
		font-size: var(--fs-h3);
		line-height: var(--lh-relaxed-heading);
		margin: var(--space-2) 0 0;
	}

	.tertiary-item h3 a {
		color: var(--color-text-primary);
		text-decoration: none;
	}

	.tertiary-item h3 a:hover {
		color: var(--color-accent);
	}

	/* ---------- Older entries ---------- */
	.older-entries {
		text-align: center;
		padding: var(--space-10) 0;
	}

	.older-link {
		font-family: var(--font-mono);
		font-size: var(--fs-caption);
		letter-spacing: var(--ls-label);
		text-transform: uppercase;
		text-decoration: none;
		color: var(--color-text-secondary);
		border-bottom: var(--border-hairline) solid var(--color-border);
		padding-bottom: var(--space-0-5);
	}

	.older-link:hover {
		color: var(--color-accent);
		border-color: var(--color-accent);
	}

	/* ---------- Substack cross-post CTA ---------- */
	.substack-cta {
		text-align: center;
		border-top: var(--border-hairline) solid var(--color-border);
		padding: var(--space-8) 0 var(--space-22-5);
	}

	.substack-label {
		font-family: var(--font-mono);
		font-size: var(--fs-eyebrow);
		letter-spacing: var(--ls-caps);
		text-transform: uppercase;
		color: var(--color-text-muted);
		display: block;
		margin-bottom: var(--space-3);
	}

	.substack-link {
		font-family: var(--font-mono);
		font-size: var(--fs-caption);
		letter-spacing: var(--ls-tight-label);
		text-transform: uppercase;
		text-decoration: none;
		color: var(--color-accent);
		border-bottom: var(--border-hairline) solid var(--color-border);
		padding-bottom: var(--space-0-5);
		display: inline-block;
	}

	.substack-link:hover {
		border-color: var(--color-accent);
	}

	/* ---------- Empty state ---------- */
	.journal-empty {
		padding: var(--space-15) 0 var(--space-30);
	}

	.empty {
		font-family: var(--font-display);
		font-style: italic;
		font-size: var(--fs-prose-quote);
		color: var(--color-text-secondary);
	}

	@media (max-width: 768px) {
		.masthead {
			padding: var(--space-8) 0 var(--space-8);
		}

		/* .masthead h1 font-size no longer needs an override here — it now
		   reads from --fs-display, which already drops to 26px at this
		   breakpoint via typography.css's own media query. */

		.rank-primary-inner {
			grid-template-columns: 1fr;
			gap: var(--space-10);
		}

		.lead-story {
			border-right: none;
			padding-right: 0;
			border-bottom: var(--border-hairline) solid var(--color-border);
			padding-bottom: var(--space-8);
		}

		.lead-story .excerpt-columns {
			column-count: 1;
		}

		.secondary-story {
			padding-left: 0;
		}

		.tertiary-grid {
			grid-template-columns: 1fr;
		}

		.tertiary-item {
			padding: var(--space-6) 0;
		}

		.tertiary-item:first-child {
			padding-top: 0;
		}

		.tertiary-item:last-child {
			padding-bottom: 0;
		}

		.tertiary-item:not(:last-child) {
			border-right: none;
			border-bottom: var(--border-hairline) solid var(--color-border);
		}

		.issue-bar-inner {
			align-items: flex-start;
		}
	}
</style>
