---
import { getCollection } from 'astro:content';
import FormattedDate from '../../components/FormattedDate.astro';
import ResourceIcon from '../../components/ResourceIcon.astro';
import Layout from '../../layouts/Layout.astro';
import { CATEGORY_LABELS } from '../../lib/journal-labels';

const allPosts = (await getCollection('journal', ({ data }) => !data.draft)).sort(
	(a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);

// Guides are real journal articles (articleType: 'guide') rendered under
// their own section below rather than in the tiered ranking — pulled out
// of the pool before tier assignment so they never leak into Tier 1–3.
const guides = allPosts.filter((post) => post.data.articleType === 'guide');
const articles = allPosts.filter((post) => post.data.articleType !== 'guide');

// Lead priority: response-type only, carried forward from the earlier
// newspaper brief. The redesign brief explicitly asked whether this still
// holds under the new hub framing — defaulting to yes: a hub meeting
// someone mid-crisis should still lead with a first-person piece over a
// research summary. Flagged for confirmation, not silently assumed.
const responsePosts = articles.filter((post) => post.data.articleType === 'response');
const lead = responsePosts[0];

const remaining = articles.filter((post) => post.id !== lead?.id);

// Starting proportions, not hard rules — see design brief §3.5. Tiers
// degrade gracefully: with few articles, Tier 2/3 and "older entries"
// simply end up empty and don't render.
const SIDEBAR_TARGET = 3;
const TIER2_TARGET = 3;
const TIER3_CAP = 8;

const sidebar = remaining.slice(0, SIDEBAR_TARGET);
const afterSidebar = remaining.slice(SIDEBAR_TARGET);
const tier2 = afterSidebar.slice(0, TIER2_TARGET);
const afterTier2 = afterSidebar.slice(TIER2_TARGET);
const tier3 = afterTier2.slice(0, TIER3_CAP);
const older = afterTier2.slice(TIER3_CAP);
---

<Layout
	title="Field Journal — Ben Maclaren"
	description="Common questions from clients, worked through in plain terms. Field notes on counselling from Ben Maclaren, counsellor in Canberra, ACT."
>
	<div class="wip-banner">
		<p>This page is a work in progress and not currently in use.</p>
	</div>

	<div class="wrap top-nav">
		<a class="back-link" href="/">← Home</a>
	</div>

	<section class="masthead">
		<svg class="masthead-motif" viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
			<circle cx="100" cy="100" r="6" fill="none" stroke-width="1.4"></circle>
			<circle cx="100" cy="100" r="20" fill="none" stroke-width="1.4"></circle>
			<circle cx="100" cy="100" r="38" fill="none" stroke-width="1.2" opacity="0.75"></circle>
			<circle cx="100" cy="100" r="60" fill="none" stroke-width="1" opacity="0.5"></circle>
			<circle cx="100" cy="100" r="86" fill="none" stroke-width="0.8" opacity="0.3"></circle>
		</svg>
		<div class="wrap">
			<span class="eyebrow">Notes on the work</span>
			<h1>Field Journal</h1>
			<p class="subtitle">Common questions from clients, worked through in plain terms.</p>
		</div>
	</section>

	{
		!lead ? (
			<section class="journal-empty">
				<div class="wrap">
					<p class="empty">No articles published yet — check back soon.</p>
				</div>
			</section>
		) : (
			<>
				<section class="tier1">
					<div class="wrap tier1-inner">
						<article class="lead">
							<span class="kicker">
								<span class="kicker-category">{CATEGORY_LABELS[lead.data.category]}</span>
								<span class="kicker-date">
									{' '}
									· <FormattedDate date={lead.data.date} />
								</span>
							</span>
							<h2>
								<a href={`/journal/${lead.id}/`}>{lead.data.title}</a>
							</h2>
							<p class="lead-excerpt">{lead.data.description}</p>
						</article>
						{sidebar.length > 0 && (
							<aside class="sidebar">
								<span class="sidebar-header">Also worth reading</span>
								<ul class="sidebar-list">
									{sidebar.map((post) => (
										<li>
											<span class="sidebar-kicker">
												{CATEGORY_LABELS[post.data.category]} · <FormattedDate date={post.data.date} />
											</span>
											<h3>
												<a href={`/journal/${post.id}/`}>{post.data.title}</a>
											</h3>
										</li>
									))}
								</ul>
							</aside>
						)}
					</div>
				</section>

				{tier2.length > 0 && (
					<section class="tier2">
						<div class="wrap tier2-grid" style={`--tier2-count: ${tier2.length}`}>
							{tier2.map((post) => (
								<article class="tier2-item">
									<span class="tier2-kicker">
										{CATEGORY_LABELS[post.data.category]} · <FormattedDate date={post.data.date} />
									</span>
									<h3>
										<a href={`/journal/${post.id}/`}>{post.data.title}</a>
									</h3>
									<p class="tier2-excerpt">{post.data.description}</p>
								</article>
							))}
						</div>
					</section>
				)}

				{tier3.length > 0 && (
					<section class="tier3">
						<div class="wrap">
							<ul class="tier3-list">
								{tier3.map((post) => (
									<li class="tier3-row">
										<span class="tier3-date">
											<FormattedDate date={post.data.date} />
										</span>
										<h3 class="tier3-headline">
											<a href={`/journal/${post.id}/`}>{post.data.title}</a>
										</h3>
										<span class="tier3-tag">{CATEGORY_LABELS[post.data.category]}</span>
									</li>
								))}
							</ul>
						</div>
					</section>
				)}

				{older.length > 0 && (
					<div class="older-entries">
						<a class="older-link" href="/journal/archive">
							Older entries →
						</a>
					</div>
				)}
			</>
		)
	}

	{
		guides.length > 0 && (
			<section class="guides">
				<div class="wrap">
					<div class="guides-header">
						<h2>Guides</h2>
						<p class="guides-note">Practical walk-throughs for navigating the system</p>
					</div>
					<div class="guides-grid">
						{guides.map((guide) => (
							<a class="guide-tile" href={`/journal/${guide.id}/`}>
								<div class="guide-tile-top">
									<ResourceIcon icon={guide.data.icon ?? 'file-text'} size={20} />
									<span class="guide-tag">Guide</span>
								</div>
								<h3 class="guide-title">{guide.data.title}</h3>
								<p class="guide-desc">{guide.data.description}</p>
							</a>
						))}
					</div>
				</div>
			</section>
		)
	}
</Layout>

<style>
	.wip-banner {
		background: var(--color-accent-solid);
		padding: var(--space-2) var(--space-4);
		text-align: center;
	}

	.wip-banner p {
		margin: 0;
		font-family: var(--font-mono);
		font-size: var(--fs-caption);
		letter-spacing: var(--ls-label);
		text-transform: uppercase;
		color: var(--color-on-accent);
	}

	.top-nav {
		padding-top: var(--space-10);
	}

	.back-link {
		font-family: var(--font-mono);
		font-size: var(--fs-caption);
		letter-spacing: var(--ls-label);
		text-transform: uppercase;
		text-decoration: none;
		color: var(--color-text-secondary);
		display: inline-block;
	}

	.back-link:hover {
		color: var(--color-accent);
	}

	/* ---------- Masthead ---------- */
	.masthead {
		position: relative;
		overflow: hidden;
		text-align: center;
		padding: var(--space-12) 0 var(--space-14);
		border-bottom: var(--border-strong) solid var(--color-border-strong);
	}

	.masthead-motif {
		position: absolute;
		top: -30px;
		right: -30px;
		width: 220px;
		height: 220px;
		opacity: 0.18;
		z-index: 0;
		color: var(--terracotta);
		pointer-events: none;
	}

	.masthead-motif circle {
		stroke: currentColor;
	}

	.masthead .wrap {
		position: relative;
		z-index: 1;
	}

	.masthead .eyebrow {
		font-size: var(--fs-caption);
		letter-spacing: var(--ls-wide-label);
		margin-bottom: var(--space-3-5);
		display: block;
	}

	.masthead h1 {
		font-size: var(--fs-display);
		font-weight: var(--fw-medium);
		margin-bottom: var(--space-3);
	}

	.subtitle {
		font-family: var(--font-display);
		font-style: italic;
		font-weight: var(--fw-regular);
		font-size: var(--fs-h3);
		color: var(--color-text-secondary);
		max-width: 480px;
		margin: 0 auto;
	}

	/* ---------- Tier 1: lead + sidebar ---------- */
	.tier1 {
		padding: var(--space-14) 0;
	}

	.tier1-inner {
		display: grid;
		grid-template-columns: 1.6fr 1fr;
		gap: 0;
		align-items: start;
	}

	.tier1-inner:not(:has(.sidebar)) .lead {
		border-right: none;
		padding-right: 0;
	}

	.lead {
		border-right: var(--border-hairline) solid var(--color-border);
		padding-right: var(--space-8);
	}

	.lead .kicker {
		font-family: var(--font-mono);
		font-size: var(--fs-eyebrow);
		letter-spacing: var(--ls-caps);
		text-transform: uppercase;
		display: block;
		margin-bottom: var(--space-3);
	}

	.kicker-category {
		color: var(--color-accent);
	}

	.kicker-date {
		color: var(--color-text-muted);
	}

	.lead h2 {
		font-size: var(--fs-lead-headline);
		line-height: var(--lh-tight);
		margin-bottom: var(--space-5);
	}

	.lead h2 a {
		color: var(--color-text-primary);
		text-decoration: none;
	}

	.lead h2 a:hover {
		color: var(--color-accent);
	}

	.lead-excerpt {
		font-size: var(--fs-h3);
		line-height: var(--lh-excerpt);
		color: var(--color-text-body);
		margin: 0;
	}

	.lead-excerpt::first-letter {
		font-family: var(--font-display);
		font-size: var(--fs-drop-cap);
		color: var(--color-text-primary);
		float: left;
		/* Cosmetic baseline tweak for this one oversized glyph, not a
		   reusable text line-height — excluded from the token scale
		   deliberately, same as .prose code's 0.9em elsewhere. */
		line-height: 0.8;
		padding-right: var(--space-2);
		padding-top: var(--space-1);
	}

	.sidebar {
		padding-left: var(--space-8);
	}

	.sidebar-header {
		font-family: var(--font-mono);
		font-size: var(--fs-eyebrow);
		letter-spacing: var(--ls-caps);
		text-transform: uppercase;
		color: var(--color-text-muted);
		display: block;
		padding-bottom: var(--space-3);
		margin-bottom: var(--space-5);
		border-bottom: var(--border-hairline) solid var(--color-border);
	}

	.sidebar-list {
		list-style: none;
		margin: 0;
		padding: 0;
	}

	.sidebar-list li {
		padding: var(--space-4) 0;
		border-bottom: var(--border-hairline) solid var(--color-border);
	}

	.sidebar-list li:first-child {
		padding-top: 0;
	}

	.sidebar-list li:last-child {
		border-bottom: none;
		padding-bottom: 0;
	}

	.sidebar-kicker {
		font-family: var(--font-mono);
		font-size: var(--fs-micro);
		letter-spacing: var(--ls-caps);
		text-transform: uppercase;
		color: var(--color-text-muted);
		display: block;
		margin-bottom: var(--space-1-5);
	}

	.sidebar-list h3 {
		font-size: var(--fs-sidebar-headline);
		font-weight: var(--fw-medium);
		line-height: var(--lh-snug);
	}

	.sidebar-list h3 a {
		color: var(--color-text-primary);
		text-decoration: none;
	}

	.sidebar-list h3 a:hover {
		color: var(--color-accent);
	}

	/* ---------- Tier 2: row of three ---------- */
	.tier2 {
		padding: var(--space-12) 0;
		border-top: var(--border-hairline) solid var(--color-border);
	}

	.tier2-grid {
		display: grid;
		grid-template-columns: repeat(var(--tier2-count, 3), 1fr);
	}

	.tier2-item {
		padding: 0 var(--space-6);
	}

	.tier2-item:first-child {
		padding-left: 0;
	}

	.tier2-item:last-child {
		padding-right: 0;
	}

	.tier2-item:not(:last-child) {
		border-right: var(--border-hairline) solid var(--color-border);
	}

	.tier2-kicker {
		font-family: var(--font-mono);
		font-size: var(--fs-eyebrow);
		letter-spacing: var(--ls-caps);
		text-transform: uppercase;
		color: var(--color-text-muted);
		display: block;
		margin-bottom: var(--space-3);
	}

	.tier2-item h3 {
		font-size: var(--fs-tier2-headline);
		line-height: var(--lh-snug);
		margin-bottom: var(--space-2);
	}

	.tier2-item h3 a {
		color: var(--color-text-primary);
		text-decoration: none;
	}

	.tier2-item h3 a:hover {
		color: var(--color-accent);
	}

	.tier2-excerpt {
		font-size: var(--fs-caption);
		color: var(--color-text-muted);
		margin: 0;
	}

	/* ---------- Tier 3: plain list ---------- */
	.tier3 {
		padding: var(--space-8) 0;
	}

	.tier3-list {
		list-style: none;
		margin: 0;
		padding: 0;
	}

	.tier3-row {
		display: flex;
		align-items: baseline;
		gap: var(--space-5);
		padding: var(--space-3) 0;
		border-bottom: var(--border-hairline) solid var(--color-border);
	}

	.tier3-row:last-child {
		border-bottom: none;
	}

	.tier3-date {
		flex: 0 0 80px;
		font-family: var(--font-mono);
		font-size: var(--fs-caption);
		color: var(--color-text-muted);
	}

	.tier3-headline {
		flex: 1;
		font-size: var(--fs-h3);
		font-weight: var(--fw-regular);
	}

	.tier3-headline a {
		color: var(--color-text-primary);
		text-decoration: none;
	}

	.tier3-headline a:hover {
		color: var(--color-accent);
	}

	.tier3-tag {
		flex: 0 0 auto;
		font-family: var(--font-mono);
		font-size: var(--fs-micro);
		letter-spacing: var(--ls-caps);
		text-transform: uppercase;
		color: var(--color-text-muted);
	}

	/* ---------- Older entries ---------- */
	.older-entries {
		text-align: center;
		padding: var(--space-10) 0;
	}

	.older-link {
		font-family: var(--font-mono);
		font-size: var(--fs-caption);
		letter-spacing: var(--ls-label);
		text-transform: uppercase;
		text-decoration: none;
		color: var(--color-text-secondary);
		border-bottom: var(--border-hairline) solid var(--color-border);
		padding-bottom: var(--space-0-5);
	}

	.older-link:hover {
		color: var(--color-accent);
		border-color: var(--color-accent);
	}

	/* ---------- Guides ---------- */
	.guides {
		padding: var(--space-14) 0 var(--space-20);
		border-top: var(--border-hairline) solid var(--color-border);
	}

	.guides-header {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		flex-wrap: wrap;
		gap: var(--space-2) var(--space-5);
		margin-bottom: var(--space-8);
	}

	.guides-header h2 {
		font-size: var(--fs-tagline);
		font-weight: var(--fw-medium);
	}

	.guides-note {
		font-family: var(--font-display);
		font-style: italic;
		font-size: var(--fs-caption);
		color: var(--color-text-muted);
		margin: 0;
	}

	.guides-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: var(--space-6);
	}

	.guide-tile {
		display: block;
		background: var(--color-bg-card);
		border-radius: var(--radius-card);
		padding: var(--space-6);
		text-decoration: none;
		color: inherit;
		transition:
			transform 0.15s ease,
			box-shadow 0.15s ease;
	}

	.guide-tile:hover {
		transform: translateY(-2px);
		box-shadow: 0 10px 24px rgba(56, 44, 36, 0.1);
	}

	.guide-tile-top {
		display: flex;
		align-items: center;
		justify-content: space-between;
		margin-bottom: var(--space-4);
	}

	.guide-tag {
		font-family: var(--font-mono);
		font-size: var(--fs-micro);
		letter-spacing: var(--ls-caps);
		text-transform: uppercase;
		color: var(--color-text-muted);
	}

	.guide-title {
		font-size: var(--fs-sidebar-headline);
		font-weight: var(--fw-medium);
		color: var(--color-text-primary);
		margin: 0 0 var(--space-2);
		transition: color 0.15s ease;
	}

	.guide-tile:hover .guide-title {
		color: var(--color-accent);
	}

	.guide-desc {
		font-size: var(--fs-caption);
		color: var(--color-text-muted);
		margin: 0;
	}

	/* ---------- Empty state ---------- */
	.journal-empty {
		padding: var(--space-15) 0 var(--space-30);
	}

	.empty {
		font-family: var(--font-display);
		font-style: italic;
		font-size: var(--fs-prose-quote);
		color: var(--color-text-secondary);
	}

	@media (max-width: 820px) {
		.tier1-inner {
			grid-template-columns: 1fr;
			gap: var(--space-8);
		}

		.lead {
			border-right: none;
			padding-right: 0;
			border-bottom: var(--border-hairline) solid var(--color-border);
			padding-bottom: var(--space-8);
		}

		.sidebar {
			padding-left: 0;
		}

		.tier2-grid {
			grid-template-columns: 1fr;
		}

		.tier2-item {
			padding: var(--space-6) 0;
		}

		.tier2-item:not(:last-child) {
			border-right: none;
			border-bottom: var(--border-hairline) solid var(--color-border);
		}

		.tier2-item:first-child {
			padding-top: 0;
		}

		.tier2-item:last-child {
			padding-bottom: 0;
			border-bottom: none;
		}

		.guides-grid {
			grid-template-columns: 1fr;
		}
	}

	@media (max-width: 480px) {
		.tier3-row {
			flex-wrap: wrap;
			gap: var(--space-1) var(--space-3);
		}

		.tier3-date {
			flex: 0 0 auto;
		}

		.tier3-tag {
			flex-basis: 100%;
		}
	}
</style>
