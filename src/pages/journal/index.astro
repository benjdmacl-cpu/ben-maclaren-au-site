---
import { getCollection } from 'astro:content';
import FormattedDate from '../../components/FormattedDate.astro';
import Layout from '../../layouts/Layout.astro';

const posts = (await getCollection('journal', ({ data }) => !data.draft)).sort(
	(a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
---

<Layout
	title="Journal — Ben Maclaren"
	description="Field notes on counselling, presence, and change from Ben Maclaren, counsellor in Canberra, ACT."
>
	<section class="journal-hero">
		<svg class="journal-motif" viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
			<circle cx="100" cy="100" r="6" fill="none" stroke-width="1.4"></circle>
			<circle cx="100" cy="100" r="20" fill="none" stroke-width="1.4"></circle>
			<circle cx="100" cy="100" r="38" fill="none" stroke-width="1.2" opacity="0.75"></circle>
			<circle cx="100" cy="100" r="60" fill="none" stroke-width="1" opacity="0.5"></circle>
			<circle cx="100" cy="100" r="86" fill="none" stroke-width="0.8" opacity="0.3"></circle>
		</svg>
		<div class="wrap">
			<span class="eyebrow">Journal</span>
			<h1>Field notes on the work.</h1>
			<p class="tagline">Occasional writing on counselling, non-directive practice, and what actually helps.</p>
		</div>
	</section>

	<section class="journal-list">
		<div class="wrap">
			{
				posts.length === 0 ? (
					<p class="empty">No articles published yet — check back soon.</p>
				) : (
					<div class="journal-grid">
						{posts.map((post) => (
							<a class="journal-card" href={`/journal/${post.id}/`}>
								<span class="label">
									<FormattedDate date={post.data.date} />
								</span>
								<h2>{post.data.title}</h2>
								<p>{post.data.description}</p>
								<span class="read-more">Read the piece →</span>
							</a>
						))}
					</div>
				)
			}
		</div>
	</section>
</Layout>

<style>
	.journal-hero {
		position: relative;
		overflow: hidden;
		padding: 110px 0 60px;
	}

	.journal-motif {
		position: absolute;
		top: -40px;
		right: -40px;
		width: 280px;
		height: 280px;
		opacity: 0.22;
		z-index: 0;
		color: var(--terracotta);
		pointer-events: none;
	}

	.journal-motif circle {
		stroke: currentColor;
	}

	.journal-hero .wrap {
		position: relative;
		z-index: 1;
	}

	.journal-hero .eyebrow {
		margin-bottom: 18px;
		display: block;
	}

	.journal-hero h1 {
		font-size: clamp(36px, 5vw, 52px);
		line-height: 1.1;
		max-width: 720px;
		margin-bottom: 22px;
	}

	.journal-hero .tagline {
		font-family: 'Fraunces', serif;
		font-style: italic;
		font-weight: 400;
		font-size: 20px;
		color: var(--ink-soft);
		max-width: 480px;
		margin: 0;
	}

	.journal-list {
		padding: 0 0 120px;
	}

	.empty {
		font-family: 'Fraunces', serif;
		font-style: italic;
		font-size: 20px;
		color: var(--ink-soft);
	}

	.journal-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
		gap: 32px;
	}

	.journal-card {
		display: block;
		background: var(--cream-deep);
		border: 1px solid var(--line);
		padding: 32px;
		text-decoration: none;
		color: inherit;
		border-radius: 2px;
		transition:
			transform 0.15s ease,
			box-shadow 0.15s ease;
	}

	.journal-card:hover {
		transform: translateY(-2px);
		box-shadow: 0 10px 24px rgba(56, 44, 36, 0.1);
	}

	.journal-card .label {
		font-family: 'IBM Plex Mono', monospace;
		font-size: 12px;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: var(--terracotta-deep);
		margin-bottom: 14px;
		display: block;
	}

	.journal-card h2 {
		font-size: 22px;
		line-height: 1.25;
		margin-bottom: 12px;
		transition: color 0.15s ease;
	}

	.journal-card:hover h2 {
		color: var(--terracotta-deep);
	}

	.journal-card p {
		color: var(--ink-soft);
		font-size: 15px;
		margin: 0 0 20px;
	}

	.journal-card .read-more {
		font-family: 'IBM Plex Mono', monospace;
		font-size: 12px;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--ink-soft);
		transition:
			color 0.15s ease,
			letter-spacing 0.15s ease;
	}

	.journal-card:hover .read-more {
		color: var(--terracotta-deep);
		letter-spacing: 0.12em;
	}

	@media (max-width: 720px) {
		.journal-hero {
			padding: 80px 0 40px;
		}

		.journal-list {
			padding: 0 0 80px;
		}

		.journal-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
